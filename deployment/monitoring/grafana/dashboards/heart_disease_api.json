{
  "title": "Heart Disease API — Live Metrics",
  "uid": "heart-disease-api",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total prediction requests",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(prediction_requests_total)", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / second (1m avg)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(prediction_requests_total[1m]))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 latency (s)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(prediction_request_latency_seconds_bucket[5m])) by (le))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 4 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Disease vs No-Disease",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum by (predicted_class) (predictions_by_class_total)", "refId": "A", "legendFormat": "class={{predicted_class}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate (per second)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum(rate(prediction_requests_total[1m]))", "refId": "A", "legendFormat": "req/s" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency percentiles (s)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(prediction_request_latency_seconds_bucket[5m])) by (le))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(prediction_request_latency_seconds_bucket[5m])) by (le))", "refId": "B", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, sum(rate(prediction_request_latency_seconds_bucket[5m])) by (le))", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Predictions by class (rate)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum by (predicted_class) (rate(predictions_by_class_total[1m]))", "refId": "A", "legendFormat": "class={{predicted_class}}" }
      ]
    }
  ]
}
